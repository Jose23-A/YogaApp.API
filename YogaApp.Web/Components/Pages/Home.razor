@page "/"
@rendermode InteractiveServer
@using YogaApp.Web.DTOs
@using YogaApp.Web.Services
@inject AlumnoService AlumnoService

<PageTitle>Home</PageTitle>

<h1>Bienvenido al Sistema de Yoga</h1>

<div class="card p-4" style="max-width: 500px;">
    <h3>Alta Rápida de Alumno</h3>

    <EditForm Model="@nuevoAlumno" OnValidSubmit="GuardarAlumno">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Nombre:</label>
            <InputText @bind-Value="nuevoAlumno.Nombre" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Email:</label>
            <InputText @bind-Value="nuevoAlumno.Email" class="form-control" />
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert alert-info mt-2">@mensaje</div>
        }

        <button type="submit" class="btn btn-primary mt-3">Guardar Alumno</button>
    </EditForm>
</div>

@code {
    // Variables (Hoja D)
    private CreateStudentDto nuevoAlumno = new CreateStudentDto();
    private string mensaje = "";

    // Lógica (Hoja C)
    private async Task GuardarAlumno()
    {
        mensaje = "Procesando...";

        try
        {
            var exito = await AlumnoService.CrearAlumnoAsync(nuevoAlumno);

            if (exito)
            {
                mensaje = "✅ ¡Alumno guardado correctamente!";
                nuevoAlumno = new CreateStudentDto(); // Limpiar pantalla
            }
            else
            {
                mensaje = "❌ Error: La API no pudo guardar.";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error Técnico: {ex.Message}";
        }
    }
}