@page "/"
<PageTitle>YogaApp - Tu espacio de paz</PageTitle>

@* ==========================================
   SECCIÓN 1: HERO (Portada Gigante)
========================================== *@
<div class="hero-section d-flex flex-column justify-center align-center">
    <MudText Typo="Typo.h1" Color="Color.Surface" Class="mb-4 text-center font-weight-bold" Style="color: #FFFFFF; text-shadow: 2px 2px 8px rgba(0,0,0,0.7);">
        Encuentra Tu Equilibrio
    </MudText>
    <MudText Typo="Typo.h5" Class="mb-8 text-center px-4" Style="color: #FFFFFF; max-width: 800px; text-shadow: 1px 1px 4px rgba(0,0,0,0.9);">
        Conéctate con tu cuerpo y mente en un entorno diseñado para tu bienestar.
    </MudText>
    <MudButton Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Class="rounded-pill px-10 py-3 font-weight-bold text-h6" OnClick="ScrollToCalendario">
        VER HORARIOS
    </MudButton>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-16">
    @* ==========================================
       SECCIÓN 2: HISTORIA (Fotos Intercaladas)
    ========================================== *@

    @* Bloque 1: Imagen Izquierda, Texto Derecha *@
    <MudGrid Class="mb-16" Spacing="6" AlignItems="AlignItems.Center">
        <MudItem xs="12" md="6">
            <MudImage Src="https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?q=80&w=800&auto=format&fit=crop" Alt="Meditación" Elevation="4" Class="rounded-lg" Width="100" Style="width: 100%; height: 350px; object-fit: cover;" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold mb-4">Conecta con tu interior</MudText>
            <MudText Typo="Typo.body1" Class="text-muted" Style="font-size: 1.1rem; line-height: 1.8;">
                Nuestras clases de meditación guiada están diseñadas para ayudarte a soltar el estrés de la rutina diaria.
                Aprende a respirar, a estar en el momento presente y a encontrar esa calma que tanto necesitas después de un largo día de trabajo.
            </MudText>
        </MudItem>
    </MudGrid>

    @* Bloque 2: Texto Izquierda, Imagen Derecha (Corregido y con nueva foto) *@
    <MudGrid Class="mb-16" Spacing="6" AlignItems="AlignItems.Center">
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold mb-4">Fuerza y Flexibilidad</MudText>
            <MudText Typo="Typo.body1" Class="text-muted" Style="font-size: 1.1rem; line-height: 1.8;">
                A través del Vinyasa Yoga, logramos unir el movimiento con la respiración.
                Fortalece tus músculos, mejora tu postura y gana una flexibilidad que transformará tu calidad de vida, sin importar tu nivel de experiencia.
            </MudText>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudImage Src="https://images.unsplash.com/photo-1575052814086-f385e2e2ad1b?q=80&w=800&auto=format&fit=crop" Alt="Vinyasa Yoga" Elevation="4" Class="rounded-lg" Style="width: 100%; height: 350px; object-fit: cover;" />
        </MudItem>
    </MudGrid>

    @* Bloque 3: Imagen Izquierda, Texto Derecha *@
    <MudGrid Class="mb-16" Spacing="6" AlignItems="AlignItems.Center">
        <MudItem xs="12" md="6">
            <MudImage Src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=800&auto=format&fit=crop" Alt="Bienestar" Elevation="4" Class="rounded-lg" Width="100" Style="width: 100%; height: 350px; object-fit: cover;" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold mb-4">Comunidad y Bienestar</MudText>
            <MudText Typo="Typo.body1" Class="text-muted" Style="font-size: 1.1rem; line-height: 1.8;">
                No somos solo un estudio, somos una comunidad. Disfruta de un ambiente cálido, libre de juicios,
                donde cada práctica es un paso más hacia tu mejor versión. Te acompañamos en cada asana.
            </MudText>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-16" />

    @* ==========================================
       SECCIÓN 3: CALENDARIO PREMIUM (Tarjetas)
    ========================================== *@
    <div id="seccion-calendario" class="pt-8 mb-16">
        <MudText Typo="Typo.h2" Color="Color.Primary" Align="Align.Center" Class="font-weight-bold mb-2">Próximas Clases</MudText>
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-10 text-muted">Reserva tu lugar hoy mismo</MudText>

        <MudGrid Justify="Justify.Center">
            @* Tarjeta de Clase 1 (Diseño de prueba) *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-xl hover-efecto">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Hatha Yoga</MudText>
                            <MudText Typo="Typo.body2" Class="text-muted">Prof. Laura Gómez</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="Color.Secondary" Size="Size.Small">Principiantes</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">Lunes 14 de Marzo</MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">18:00 - 19:15 hs</MudText>
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="d-flex justify-center pb-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="rounded-pill px-8">Reservar Lugar</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Tarjeta de Clase 2 *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-xl hover-efecto">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">Vinyasa Flow</MudText>
                            <MudText Typo="Typo.body2" Class="text-muted">Prof. Marcos Díaz</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Avanzado</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">Lunes 14 de Marzo</MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">19:30 - 20:45 hs</MudText>
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="d-flex justify-center pb-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="rounded-pill px-8">Reservar Lugar</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </div>
</MudContainer>

<style>
    /* El fondo con la imagen premium */
    .hero-section {
        background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=1920&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        height: 85vh;
        border-radius: 0 0 48px 48px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    /* Magia para que el bloque 2 se de vuelta en celulares */
    @@media (min-width: 960px) {

        .texto-derecha {
            padding-left: 3rem !important;
        }
    }

    /* Efecto elegante al pasar el mouse por las tarjetas de clases */
    .hover-efecto {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-efecto:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(92, 131, 116, 0.2) !important; /* Usa el tono verde salvia */
        }
</style>

@code {
    // Función para que el botón del Hero baje suavemente hasta el calendario
    [Inject] IJSRuntime JSRuntime { get; set; }

    private async Task ScrollToCalendario()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('seccion-calendario').scrollIntoView({behavior: 'smooth'})");
    }
}