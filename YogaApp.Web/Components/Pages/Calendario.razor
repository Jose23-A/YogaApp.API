@page "/calendario"
@using YogaApp.Web.DTOs
@using YogaApp.Web.Services
@using YogaApp.API.Entities
@inject HttpClient Http
@inject ReservaService ReservaService
@inject ISnackbar Snackbar

<div class="container mt-4">
    <h2 class="text-center mb-4">📅 Calendario Semanal</h2>

    @if (sesiones == null)
    {
        <div class="text-center"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered text-center shadow">
                <thead class="table-dark">
                    <tr>
                        <th>Horario</th>
                        <th>Lunes</th>
                        <th>Martes</th>
                        <th>Miércoles</th>
                        <th>Jueves</th>
                        <th>Viernes</th>
                        <th>Sábado</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int hora = 8; hora <= 20; hora++)
                    {
                        <tr>
                            <td class="align-middle fw-bold bg-light">@hora:00</td>
                            @for (int dia = 1; dia <= 6; dia++)
                            {
                                <td>
                                    @{
                                        var clase = ObtenerClase(dia, hora);
                                    }
                                    @if (clase != null)
                                    {
                                        <div class="card border-0 shadow-sm text-white p-2"
                                             style="background-color: #6f42c1; cursor: pointer;"
                                             @onclick="() => SeleccionarClase(clase)">
                                            <small>@clase.ClassDefinition?.Nombre</small>
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* SECCIÓN DE CONFIRMACIÓN *@
@if (claseSeleccionada != null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mt-4 mx-4 shadow">
        <MudText Typo="Typo.h6">Confirmar reserva para: <strong>@claseSeleccionada.ClassDefinition?.Nombre</strong></MudText>
        <MudText Typo="Typo.body2">Horario: @claseSeleccionada.FechaHoraInicio.ToShortTimeString() hs</MudText>
        
        <div class="d-flex gap-2 mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ConfirmarInscripcion" Disabled="@_cargando">
                @if (_cargando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {

                    <text>Confirmar Inscripción</text>
                }
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="() => claseSeleccionada = null">Cancelar</MudButton>
        </div>
    </MudAlert>
}

@code {
    private List<ClassSessionDto>? sesiones;
    private ClassSessionDto? claseSeleccionada;
    private bool _cargando = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            sesiones = await Http.GetFromJsonAsync<List<ClassSessionDto>>("api/ClassSessions");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al cargar las clases.", Severity.Error);
        }
    }

    private async Task ConfirmarInscripcion()
    {
        if (UserState.AlumnoLogueado == null)
        {
            Snackbar.Add("Debes iniciar sesión primero.", Severity.Warning);
            return;
        }

        _cargando = true;
        // Usamos el ID de la clase y el ID del alumno logueado
        var response = await ReservaService.SolicitarReservaAsync(claseSeleccionada!.Id, UserState.AlumnoLogueado.Id);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("¡Reserva exitosa!", Severity.Success);
            claseSeleccionada = null;
            // Recargamos para ver si el cupo cambió
            sesiones = await Http.GetFromJsonAsync<List<ClassSessionDto>>("api/ClassSessions");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Error: {error}", Severity.Error);
        }
        _cargando = false;
    }

    private ClassSessionDto? ObtenerClase(int dia, int hora) =>
        sesiones?.FirstOrDefault(c => (int)c.FechaHoraInicio.DayOfWeek == dia && c.FechaHoraInicio.Hour == hora);

    private void SeleccionarClase(ClassSessionDto clase) => claseSeleccionada = clase;
}